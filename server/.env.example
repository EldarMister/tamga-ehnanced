# Postgres connection string. На Railway этот var выдаёт plugin Postgres автоматически.
DATABASE_URL=postgresql://user:pass@localhost:5432/tamga

# Секрет для хеширования паролей и подписи JWT. Сгенерируй случайную строку для прода.
SECRET_KEY=change-me-in-prod-please

# Срок жизни токена в часах.
JWT_EXPIRY_HOURS=720

# Порт. На Railway выставляется автоматически в $PORT.
PORT=8000

# Разрешённые домены фронта через запятую (CORS). Пусто = все.
CORS_ORIGINS=http://localhost:5173,http://localhost:4173
