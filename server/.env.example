# Postgres connection string. Railway provides this value from the Postgres plugin.
DATABASE_URL=postgresql://user:pass@host:5432/db

# Secret for password hashing and JWT signing. Generate a random value for production.
SECRET_KEY=change-me-in-prod-please

# Token lifetime in hours.
JWT_EXPIRY_HOURS=720

# Port. Railway sets $PORT automatically.
PORT=8000

# Allowed frontend origins separated by commas. Empty = allow all.
CORS_ORIGINS=http://localhost:5173,http://localhost:4173
